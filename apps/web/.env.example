# SQLite file path. Defaults to ./dev.db locally; set to /data/cuatro.db on Fly (matches the mounted volume).
DATABASE_PATH=./dev.db

# Supabase Auth — the primary sign-in flow (magic link + Google/Apple).
# Public-by-design client keys (anon/publishable), safe in this file and in
# fly.toml [env]. NEXT_PUBLIC_ vars are inlined at BUILD time, not read at
# runtime — see fly.toml [build.args] and the Dockerfile builder stage.
#
# Dev/prod parity: local dev ALWAYS points at the local Supabase stack
# (supabase/config.toml, `supabase start`), never the hosted project —
# fill these from `supabase status` (repo root). That stack's ports are
# shifted onto 544xx (API 54421, not the 543xx default) because another
# project's stack already holds those on this machine. Magic-link emails
# sent locally land in Mailpit, not your inbox: http://127.0.0.1:54424
# (UI) / http://127.0.0.1:54424/api/v1/messages (API) — no SMTP setup
# needed. Prod's values (the dedicated hosted cuatro project) live only in
# fly.toml [env] / [build.args], never here.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Set to "1" to re-enable the legacy custom magic-link flow
# (/api/auth/request, /api/auth/verify, console-logged link). Routes 404
# when unset. Normally left off — the local Supabase stack's magic-link
# flow works end-to-end via Mailpit above — but it's kept as a fallback
# for automated E2E or whenever the local stack isn't running.
# See src/lib/session.ts#legacyAuthEnabled.
AUTH_LEGACY=

# Web push (VAPID). Unset in dev — push just no-ops until these are set.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@cuatro.app

# Set to "production" once a real email provider is wired into src/lib/mailer.ts.
MAILER=console
